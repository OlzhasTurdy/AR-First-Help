--- !u!114 &201747325
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 201747323}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0415\u0433\u0435\u0440 \u0437\u0430\u0440\u0434\u0430\u043F \u0448\u0435\u0433\u0443\u0448\u0456
    \u0436\u04E9\u0442\u0435\u043B\u0435 \u0430\u043B\u0441\u0430 \u0436\u04D9\u043D\u0435
    \u0434\u0435\u043C \u0430\u043B\u0430 \u0430\u043B\u0441\u0430, \u043E\u043D\u044B
    \u0436\u04E9\u0442\u0435\u043B\u0443\u0433\u0435 \u0438\u0442\u0435\u0440\u043C\u0435\u043B\u0435\u04A3\u0456\u0437.
    \u0416\u04E9\u0442\u0435\u043B \u2014 \u0431\u04E9\u0433\u0434\u0435 \u0437\u0430\u0442\u0442\u044B
    \u0448\u044B\u0493\u0430\u0440\u0443\u0434\u044B\u04A3 \u0435\u04A3 \u0442\u0438\u0456\u043C\u0434\u0456
    \u0442\u0430\u0431\u0438\u0493\u0438 \u0436\u043E\u043B\u044B. \u0411\u04B1\u043B
    \u043A\u0435\u0437\u0434\u0435 \u0430\u0434\u0430\u043C\u043D\u044B\u04A3 \u0430\u0440\u049B\u0430\u0441\u044B\u043D\u0430\u043D
    \u049B\u0430\u0493\u0443\u0493\u0430 \u0431\u043E\u043B\u043C\u0430\u0439\u0434\u044B,
    \u0441\u0435\u0431\u0435\u0431\u0456 \u0431\u04B1\u043B \u0431\u04E9\u0433\u0434\u0435
    \u0437\u0430\u0442\u0442\u044B \u043E\u0434\u0430\u043D \u04D9\u0440\u0456 \u0442\u0435\u0440\u0435\u04A3\u0433\u0435
    \u0438\u0442\u0435\u0440\u0456\u043F \u0436\u0456\u0431\u0435\u0440\u0443\u0456
    \u043C\u04AF\u043C\u043A\u0456\u043D.\n\n\u0415\u0433\u0435\u0440 \u0430\u0434\u0430\u043C
    \u0436\u04E9\u0442\u0435\u043B\u0435 \u0430\u043B\u043C\u0430\u0441\u0430, \u0441\u04E9\u0439\u043B\u0435\u0439
    \u0430\u043B\u043C\u0430\u0441\u0430 \u0436\u04D9\u043D\u0435 \u0442\u0430\u043C\u0430\u0493\u044B\u043D
    \u04B1\u0441\u0442\u0430\u043F \u049B\u044B\u043B\u049B\u044B\u043D\u0441\u0430,
    \u0434\u0435\u0440\u0435\u0443 \u0431\u0435\u0441 \u0440\u0435\u0442 \u0436\u0430\u0443\u044B\u0440\u044B\u043D
    \u0430\u0440\u0430\u0441\u044B\u043D\u0430\u043D \u04B1\u0440\u0443 \u04D9\u0434\u0456\u0441\u0456\u043D
    \u049B\u043E\u043B\u0434\u0430\u043D\u044B\u04A3\u044B\u0437. \u041E\u043B \u04AF\u0448\u0456\u043D
    \u0437\u0430\u0440\u0434\u0430\u043F \u0448\u0435\u0433\u0443\u0448\u0456\u043D\u0456
    \u0441\u04D9\u043B \u0430\u043B\u0493\u0430 \u0435\u04A3\u043A\u0435\u0439\u0442\u0456\u043F,
    \u0430\u043B\u0430\u049B\u0430\u043D\u043D\u044B\u04A3 \u043D\u0435\u0433\u0456\u0437\u0456\u043C\u0435\u043D
    \u0436\u0430\u0443\u044B\u0440\u044B\u043D \u043E\u0440\u0442\u0430\u0441\u044B\u043D\u0430\u043D
    \u043D\u044B\u049B \u04D9\u0440\u0456 \u0431\u0430\u0493\u044B\u0442\u0442\u0430\u043B\u0493\u0430\u043D
    \u0441\u043E\u049B\u049B\u044B\u043B\u0430\u0440 \u0436\u0430\u0441\u0430\u04A3\u044B\u0437.\n\n\u0415\u0433\u0435\u0440
    \u0441\u043E\u049B\u049B\u044B\u043B\u0430\u0440 \u043A\u04E9\u043C\u0435\u043A\u0442\u0435\u0441\u043F\u0435\u0441\u0435,
    \u0413\u0435\u0439\u043C\u043B\u0438\u0445 \u04D9\u0434\u0456\u0441\u0456\u043D\u0435
    (\u0456\u0448\u0442\u0435\u043D \u049B\u044B\u0441\u0443) \u043A\u04E9\u0448\u0456\u04A3\u0456\u0437.
    \u0417\u0430\u0440\u0434\u0430\u043F \u0448\u0435\u0433\u0443\u0448\u0456\u043D\u0456\u04A3
    \u0430\u0440\u0442\u044B\u043D\u0430 \u0442\u04B1\u0440\u044B\u043F, \u043E\u043D\u044B
    \u0435\u043A\u0456 \u049B\u043E\u043B\u044B\u04A3\u044B\u0437\u0431\u0435\u043D
    \u049B\u04B1\u0448\u0430\u049B\u0442\u0430\u04A3\u044B\u0437. \u0411\u0456\u0440
    \u049B\u043E\u043B\u044B\u04A3\u044B\u0437\u0434\u044B \u0436\u04B1\u0434\u044B\u0440\u044B\u049B\u049B\u0430
    \u0442\u04AF\u0439\u0456\u043F, \u043A\u0456\u043D\u0434\u0456\u043A \u043F\u0435\u043D
    \u0442\u04E9\u0441 \u0441\u04AF\u0439\u0435\u0433\u0456\u043D\u0456\u04A3 \u0430\u0440\u0430\u0441\u044B\u043D\u0430
    \u049B\u043E\u0439\u044B\u04A3\u044B\u0437, \u0430\u043B \u0435\u043A\u0456\u043D\u0448\u0456
    \u049B\u043E\u043B\u044B\u04A3\u044B\u0437\u0431\u0435\u043D \u0436\u04B1\u0434\u044B\u0440\u044B\u049B\u0442\u044B
    \u0436\u0430\u0443\u044B\u043F, \u0456\u0448\u043A\u0435 \u0436\u04D9\u043D\u0435
    \u0436\u043E\u0493\u0430\u0440\u044B \u049B\u0430\u0440\u0430\u0439 \u0431\u0435\u0441
    \u0440\u0435\u0442 \u0436\u044B\u043B\u0434\u0430\u043C \u04D9\u0440\u0456 \u043A\u04AF\u0448\u0442\u0456
    \u049B\u043E\u0437\u0493\u0430\u043B\u044B\u0441 \u0436\u0430\u0441\u0430\u04A3\u044B\u0437.\n\n\u0416\u04AF\u043A\u0442\u0456
    \u04D9\u0439\u0435\u043B\u0434\u0435\u0440 \u043D\u0435\u043C\u0435\u0441\u0435
    \u0434\u0435\u043D\u0435\u0441\u0456 \u04E9\u0442\u0435 \u0456\u0440\u0456 \u0430\u0434\u0430\u043C\u0434\u0430\u0440
    \u04AF\u0448\u0456\u043D \u0413\u0435\u0439\u043C\u043B\u0438\u0445 \u04D9\u0434\u0456\u0441\u0456
    \u0456\u0448 \u0442\u04B1\u0441\u044B\u043D\u0434\u0430 \u0435\u043C\u0435\u0441,
    \u043A\u0435\u0443\u0434\u0435 \u049B\u0443\u044B\u0441\u044B\u043D\u044B\u04A3
    \u043E\u0440\u0442\u0430 \u0442\u04B1\u0441\u044B\u043D\u0434\u0430 \u043E\u0440\u044B\u043D\u0434\u0430\u043B\u0430\u0434\u044B.
    \u0415\u0433\u0435\u0440 \u0431\u04E9\u0433\u0434\u0435 \u0437\u0430\u0442 \u0448\u044B\u049B\u043F\u0430\u0441\u0430
    \u0436\u04D9\u043D\u0435 \u0430\u0434\u0430\u043C \u0435\u0441-\u0442\u04AF\u0441\u0441\u0456\u0437
    \u049B\u0430\u043B\u0441\u0430, \u043E\u043D\u044B \u0434\u0435\u0440\u0435\u0443
    \u0442\u0435\u0433\u0456\u0441 \u0436\u0435\u0440\u0433\u0435 \u0436\u0430\u0442\u049B\u044B\u0437\u044B\u043F,
    \u04E9\u043A\u043F\u0435-\u0436\u04AF\u0440\u0435\u043A \u0440\u0435\u0430\u043D\u0438\u043C\u0430\u0446\u0438\u044F\u0441\u044B\u043D
    \u0431\u0430\u0441\u0442\u0430\u0443 \u043A\u0435\u0440\u0435\u043A.\n\n\u04D8\u0440\u0431\u0456\u0440
    30 \u043A\u043E\u043C\u043F\u0440\u0435\u0441\u0441\u0438\u044F\u0434\u0430\u043D
    \u043A\u0435\u0439\u0456\u043D \u0430\u0443\u044B\u0437 \u049B\u0443\u044B\u0441\u044B\u043D
    \u0442\u0435\u043A\u0441\u0435\u0440\u0456\u043F, \u0435\u0433\u0435\u0440 \u0431\u04E9\u0433\u0434\u0435
    \u0437\u0430\u0442 \u043A\u04E9\u0440\u0456\u043D\u0456\u043F \u0442\u04B1\u0440\u0441\u0430,
    \u043E\u043D\u044B \u0430\u0431\u0430\u0439\u043B\u0430\u043F \u0441\u0443\u044B\u0440\u044B\u043F
    \u0430\u043B\u044B\u04A3\u044B\u0437. \u0416\u0435\u0434\u0435\u043B \u0436\u04D9\u0440\u0434\u0435\u043C
    \u043A\u0435\u043B\u0433\u0435\u043D\u0448\u0435 \u043D\u0435\u043C\u0435\u0441\u0435
    \u0442\u044B\u043D\u044B\u0441 \u0436\u043E\u043B\u0434\u0430\u0440\u044B \u0430\u0448\u044B\u043B\u0493\u0430\u043D\u0448\u0430
    \u043A\u04E9\u043C\u0435\u043A \u043A\u04E9\u0440\u0441\u0435\u0442\u0443\u0434\u0456
    \u0442\u043E\u049B\u0442\u0430\u0442\u043F\u0430\u04A3\u044B\u0437."
