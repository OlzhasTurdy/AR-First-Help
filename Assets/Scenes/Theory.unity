    \u0441\u0435\u0431\u0435\u0431\u0456 \u0434\u0435\u0440 \u043A\u0435\u0437\u0456\u043D\u0434\u0435
    \u043A\u04E9\u0440\u0441\u0435\u0442\u0456\u043B\u0433\u0435\u043D \u043A\u04E9\u043C\u0435\u043A
    \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0430\u043B\u044B\u049B \u043C\u0435\u043A\u0435\u043C\u0435\u0433\u0435
    \u0434\u0435\u0439\u0456\u043D\u0433\u0456 \u043A\u0435\u0437\u0435\u04A3\u0434\u0435
    \u0430\u0434\u0430\u043C \u04E9\u043C\u0456\u0440\u0456\u043D\u0456\u04A3 \u0431\u0430\u0441\u0442\u044B
    \u043A\u0435\u043F\u0456\u043B\u0456 \u0431\u043E\u043B\u044B\u043F \u0442\u0430\u0431\u044B\u043B\u0430\u0434\u044B."
