  m_text: "\u0410\u043B\u0493\u0430\u0448\u049B\u044B \u043A\u04E9\u043C\u0435\u043A
    \u043A\u04E9\u0440\u0441\u0435\u0442\u0443 \u2014 \u0431\u04B1\u043B \u0430\u0434\u0430\u043C
    \u04E9\u043C\u0456\u0440\u0456\u043D \u0441\u0430\u049B\u0442\u0430\u043F \u049B\u0430\u043B\u0443\u0493\u0430
    \u0436\u04D9\u043D\u0435 \u043C\u0430\u043C\u0430\u043D \u043A\u04E9\u043C\u0435\u0433\u0456
    \u043A\u0435\u043B\u0433\u0435\u043D\u0433\u0435 \u0434\u0435\u0439\u0456\u043D
    \u0436\u0430\u0440\u0430\u049B\u0430\u0442\u0442\u044B\u04A3 \u0430\u0441\u049B\u044B\u043D\u0443\u044B\u043D
    \u0431\u043E\u043B\u0434\u044B\u0440\u043C\u0430\u0443\u0493\u0430 \u0431\u0430\u0493\u044B\u0442\u0442\u0430\u043B\u0493\u0430\u043D
    \u0448\u04B1\u0493\u044B\u043B \u0448\u0430\u0440\u0430\u043B\u0430\u0440 \u043A\u0435\u0448\u0435\u043D\u0456."
