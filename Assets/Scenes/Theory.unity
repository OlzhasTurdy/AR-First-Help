  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u049A\u0430\u0442\u0442\u044B \u049B\u0430\u043D \u043A\u0435\u0442\u0443
    \u2014 \u0431\u04B1\u043B \u0430\u0434\u0430\u043C \u04E9\u043C\u0456\u0440\u0456\u043D\u0435
    \u0442\u0456\u043A\u0435\u043B\u0435\u0439 \u049B\u0430\u0443\u0456\u043F \u0442\u04E9\u043D\u0434\u0456\u0440\u0435\u0442\u0456\u043D
    \u0436\u0430\u0493\u0434\u0430\u0439, \u0441\u0435\u0431\u0435\u0431\u0456 \u049B\u0430\u043D\u043D\u044B\u04A3
    \u043A\u04E9\u043F \u043C\u04E9\u043B\u0448\u0435\u0440\u0456\u043D \u0436\u043E\u0493\u0430\u043B\u0442\u0443
    \u0441\u0430\u043D\u0430\u0443\u043B\u044B \u043C\u0438\u043D\u0443\u0442\u0442\u0430\u0440\u0434\u0430
    \u0435\u0441\u0442\u0435\u043D \u0442\u0430\u043D\u0443\u0493\u0430 \u0436\u04D9\u043D\u0435
    \u04E9\u043B\u0456\u043C\u0433\u0435 \u04D9\u043A\u0435\u043B\u0443\u0456 \u043C\u04AF\u043C\u043A\u0456\u043D.
    \u041A\u04E9\u043C\u0435\u043A \u043A\u04E9\u0440\u0441\u0435\u0442\u0443 \u043A\u0435\u0437\u0456\u043D\u0434\u0435
    \u0435\u04A3 \u0431\u0430\u0441\u0442\u044B \u043C\u0430\u049B\u0441\u0430\u0442
    \u2014 \u049B\u0430\u043D \u0430\u0493\u044B\u043D\u044B\u043D \u043A\u0435\u0437
    \u043A\u0435\u043B\u0433\u0435\u043D \u0436\u043E\u043B\u043C\u0435\u043D \u0434\u0435\u0440\u0435\u0443
    \u0442\u043E\u049B\u0442\u0430\u0442\u0443."
