  m_text: "\u0422\u044B\u043D\u044B\u0441 \u0430\u043B\u0443 \u0436\u043E\u043B\u0434\u0430\u0440\u044B\u043D\u044B\u04A3
    \u0431\u0456\u0442\u0435\u043B\u0443\u0456 \u2014 \u0431\u04B1\u043B \u0442\u0430\u043C\u0430\u049B
    \u043D\u0435\u043C\u0435\u0441\u0435 \u0431\u04E9\u0433\u0434\u0435 \u0437\u0430\u0442\u0442\u044B\u04A3
    \u043A\u0435\u04A3\u0456\u0440\u0434\u0435\u043A\u043A\u0435 \u0442\u04AF\u0441\u0456\u043F,
    \u0430\u0443\u0430 \u0430\u0493\u044B\u043D\u044B\u043D \u0442\u043E\u043B\u044B\u049B
    \u043D\u0435\u043C\u0435\u0441\u0435 \u0456\u0448\u0456\u043D\u0430\u0440\u0430
    \u0436\u0430\u0443\u044B\u043F \u0442\u0430\u0441\u0442\u0430\u0443\u044B. \u0411\u04B1\u043B
    \u0436\u0430\u0493\u0434\u0430\u0439\u0434\u0430 \u0430\u0434\u0430\u043C \u0441\u04E9\u0439\u043B\u0435\u0439
    \u0430\u043B\u043C\u0430\u0439\u0434\u044B, \u0434\u0435\u043C \u0430\u043B\u0443\u044B
    \u049B\u0438\u044B\u043D\u0434\u0430\u0439\u0434\u044B \u0436\u04D9\u043D\u0435
    \u0431\u0435\u0442\u0456 \u043A\u04E9\u0433\u0435\u0440\u0435 \u0431\u0430\u0441\u0442\u0430\u0443\u044B
    \u043C\u04AF\u043C\u043A\u0456\u043D. \u041C\u04B1\u043D\u0434\u0430\u0439 \u0441\u04D9\u0442\u0442\u0435
    \u0441\u0430\u043D\u0430\u0443\u043B\u044B \u0441\u0435\u043A\u0443\u043D\u0434\u0442\u0430\u0440
    \u043C\u0430\u04A3\u044B\u0437\u0434\u044B \u0440\u04E9\u043B \u0430\u0442\u049B\u0430\u0440\u0430\u0434\u044B."
