  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u04E8\u043A\u043F\u0435-\u0436\u04AF\u0440\u0435\u043A \u0440\u0435\u0430\u043D\u0438\u043C\u0430\u0446\u0438\u044F\u0441\u044B
    (\u0421\u041B\u0420) \u2014 \u0431\u04B1\u043B \u0430\u043B\u0493\u0430\u0448\u049B\u044B
    \u043A\u04E9\u043C\u0435\u043A \u043A\u04E9\u0440\u0441\u0435\u0442\u0443\u0434\u0456\u04A3
    \u0435\u04A3 \u043C\u0430\u04A3\u044B\u0437\u0434\u044B \u04D9\u0434\u0456\u0441\u0456,
    \u043E\u043B \u0430\u0434\u0430\u043C\u043D\u044B\u04A3 \u0436\u04AF\u0440\u0435\u0433\u0456
    \u043C\u0435\u043D \u04E9\u043A\u043F\u0435\u0441\u0456 \u0436\u04B1\u043C\u044B\u0441
    \u0456\u0441\u0442\u0435\u043C\u0435\u0439 \u049B\u0430\u043B\u0493\u0430\u043D\u0434\u0430
    \u049B\u043E\u043B\u0434\u0430\u043D\u044B\u043B\u0430\u0434\u044B. \u0411\u04B1\u043B
    \u04D9\u0434\u0456\u0441 \u0436\u0435\u0434\u0435\u043B \u0436\u04D9\u0440\u0434\u0435\u043C
    \u043A\u0435\u043B\u0433\u0435\u043D\u0433\u0435 \u0434\u0435\u0439\u0456\u043D
    \u0437\u0430\u0440\u0434\u0430\u043F \u0448\u0435\u0433\u0443\u0448\u0456\u043D\u0456\u04A3
    \u0442\u0456\u0440\u0456 \u049B\u0430\u043B\u0443 \u043C\u04AF\u043C\u043A\u0456\u043D\u0434\u0456\u0433\u0456\u043D
    \u0430\u0440\u0442\u0442\u044B\u0440\u0430\u0434\u044B"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: db4686bf70705e14fb0ea68ea3de7996, type: 2}
